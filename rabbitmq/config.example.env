# Kubernetes config
KUBECONFIG=

# Namespace and cluster
RABBITMQ_NAMESPACE=rabbitmq
RABBITMQ_CLUSTER_NAME=rabbitmq
RABBITMQ_REPLICAS=3

# Images
# 当前默认值按 2026-06-05 官方 release 信息选择，生产应结合公司基线固定版本。
RABBITMQ_IMAGE=rabbitmq:4.3.1-management
RABBITMQ_OPERATOR_VERSION=v2.21.0
RABBITMQ_OPERATOR_IMAGE=ghcr.io/rabbitmq/cluster-operator:2.21.0
RABBITMQ_IMAGE_PLATFORM=linux/arm64
RABBITMQ_ARTIFACT_DIR=./rabbitmq/artifacts
RABBITMQ_IMAGE_TAR=
RABBITMQ_OPERATOR_IMAGE_TAR=
RABBITMQ_OPERATOR_MANIFEST=
RABBITMQ_OPERATOR_MANIFEST_URL=https://github.com/rabbitmq/cluster-operator/releases/download/v2.21.0/cluster-operator.yml
RABBITMQ_IMAGE_DOWNLOAD_TOOL=docker
CRANE_BIN=crane
RABBITMQ_DOCKER_PULL_RETRIES=5
RABBITMQ_DOCKER_PULL_RETRY_DELAY=10

# Operator
RABBITMQ_INSTALL_OPERATOR=true
RABBITMQ_OPERATOR_IMAGE_PULL_POLICY=IfNotPresent
RABBITMQ_WAIT_TIMEOUT=600s

# Storage
RABBITMQ_STORAGE_CLASS=local-path
RABBITMQ_STORAGE=20Gi

# Resources
RABBITMQ_CPU_REQUEST=500m
RABBITMQ_CPU_LIMIT=1000m
RABBITMQ_MEMORY_REQUEST=1Gi
RABBITMQ_MEMORY_LIMIT=1Gi

# RabbitMQ config
RABBITMQ_DEFAULT_QUEUE_TYPE=quorum
RABBITMQ_VM_MEMORY_HIGH_WATERMARK=0.60
RABBITMQ_DISK_FREE_LIMIT=1GB
RABBITMQ_AUTO_ENABLE_ALL_FEATURE_FLAGS=false

# Image upload to K3s nodes
# 多个节点用英文逗号分隔，例如: k3s-master-1,k3s-master-2,k3s-master-3
RABBITMQ_NODE_SSH_HOSTS=
RABBITMQ_NODE_NAMES=
SSH_USER=root
SSH_PORT=22
SSH_OPTS="-o StrictHostKeyChecking=accept-new"
RABBITMQ_K3S_IMAGES_DIR=/var/lib/rancher/k3s/agent/images
RABBITMQ_RESTART_K3S_AFTER_IMAGE_UPLOAD=false
RABBITMQ_RESET_K3S_IMAGE_CACHE=false
