# Kubernetes config
KUBECONFIG=

# Namespace
REDIS_NAMESPACE=redis

# Image
# 建议生产固定完整镜像 tag，不使用 latest。
REDIS_IMAGE=redis:7.2.4
REDIS_IMAGE_PLATFORM=linux/arm64
REDIS_ARTIFACT_DIR=./redis/artifacts
REDIS_IMAGE_TAR=

# Image upload to K3s nodes
# 多个节点用英文逗号分隔，例如: k3s-master-1,k3s-master-2,k3s-master-3
REDIS_NODE_SSH_HOSTS=
REDIS_NODE_NAMES=
SSH_USER=root
SSH_PORT=22
SSH_OPTS="-o StrictHostKeyChecking=accept-new"
REDIS_K3S_IMAGES_DIR=/var/lib/rancher/k3s/agent/images
REDIS_RESTART_K3S_AFTER_IMAGE_UPLOAD=false
REDIS_RESET_K3S_IMAGE_CACHE=false

# Auth
# 生产部署前必须修改。
REDIS_PASSWORD=change-me-use-openssl-rand-base64-24

# Redis settings
REDIS_MASTER_NAME=mymaster
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Sentinel settings
REDIS_SENTINEL_QUORUM=2
REDIS_SENTINEL_DOWN_AFTER_MS=10000
REDIS_SENTINEL_FAILOVER_TIMEOUT_MS=60000
REDIS_SENTINEL_PARALLEL_SYNCS=1

# Rollout wait
REDIS_WAIT_TIMEOUT=300s
