# Copy to vm-lab/lab.env and adjust if needed.

# VM shape. 3 x 4G is a practical minimum for K3s + Rook-Ceph smoke tests
# on the current 15G WSL2 host.
VM_PREFIX=k3s
VM_COUNT=3
VM_CPUS=2
VM_MEMORY_MB=4096
OS_DISK_SIZE=30G
CEPH_DISK_SIZE=30G

# libvirt network. The scripts use NAT via the default libvirt network.
LIBVIRT_NETWORK=default

# Ubuntu 24.04 cloud image. Override IMAGE_URL to use a local mirror or Rocky.
IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img
OS_VARIANT=ubuntu24.04

# SSH key injected into root and the default ubuntu user.
# If unset, scripts try ~/.ssh/id_ed25519.pub and then ~/.ssh/id_rsa.pub.
# SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# Packages installed inside the VM by cloud-init.
CLOUD_INIT_PACKAGE_UPDATE=true
CLOUD_INIT_PACKAGES="qemu-guest-agent curl ca-certificates socat conntrack ipset iptables nfs-common open-iscsi lvm2 cryptsetup sg3-utils"

# Optional: add extra TLS SANs to the generated K3s env, comma-separated.
TLS_SAN_VALUES_EXTRA=
