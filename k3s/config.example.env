# SSH settings
SSH_USER=root
SSH_PORT=22
SSH_OPTS="-o StrictHostKeyChecking=accept-new"

# Master nodes
# MASTER*_HOST 是节点在集群内互相访问的地址。
# MASTER*_SSH_HOST 是运维机 SSH 登录地址；不填时默认等于 MASTER*_HOST。
# 例如 OrbStack 可以写 MASTER1_HOST=192.168.x.x, MASTER1_SSH_HOST=ubuntu-1@orb。
MASTER1_NAME=k3s-master-1
MASTER1_HOST=192.168.1.11
MASTER1_SSH_HOST=
MASTER1_ARCH=auto
MASTER2_NAME=k3s-master-2
MASTER2_HOST=192.168.1.12
MASTER2_SSH_HOST=
MASTER2_ARCH=auto
MASTER3_NAME=k3s-master-3
MASTER3_HOST=192.168.1.13
MASTER3_SSH_HOST=
MASTER3_ARCH=auto

# K3s bootstrap endpoint.
# Leave empty to join master2/master3 through https://MASTER1_HOST:6443.
K3S_JOIN_ENDPOINT=
K3S_API_PORT=6443

# Generated kubeconfig server address. Leave empty to use K3S_JOIN_ENDPOINT.
KUBECONFIG_SERVER=

# Optional future API endpoint certificate SANs, comma separated.
# Example: TLS_SAN_VALUES=192.168.1.10,k3s-api.example.com
TLS_SAN_VALUES=

# K3s settings
# Production must pin a tested version. This version was validated on OrbStack arm64.
K3S_VERSION=v1.35.5+k3s1
K3S_CHANNEL=stable
K3S_TOKEN=change-me-use-openssl-rand-hex-32
K3S_CLUSTER_CIDR=10.42.0.0/16
K3S_SERVICE_CIDR=10.43.0.0/16
K3S_CLUSTER_DNS=10.43.0.10

# Cgroup settings:
# - auto: detect each host and keep K3s defaults.
# - v1/v2: require the detected host mode to match.
CGROUP_MODE=auto
# Optional kubelet cgroup driver override. Leave auto unless you have a tested OS baseline.
# Values: auto, systemd, cgroupfs
K3S_CGROUP_DRIVER=auto

# Disable bundled Traefik so ingress can be managed explicitly later.
K3S_DISABLE_COMPONENTS=traefik

# Optional image registry settings.
# K3S_PRIVATE_REGISTRY_FILE points to a local registries.yaml copied to every node.
# K3S_SYSTEM_DEFAULT_REGISTRY requires that the target registry has mirrored K3s system images.
# K3S_PAUSE_IMAGE can replace the default rancher/mirrored-pause:3.6 when Docker Hub is blocked.
K3S_PRIVATE_REGISTRY_FILE=
K3S_SYSTEM_DEFAULT_REGISTRY=
K3S_PAUSE_IMAGE=

# Online or airgap mode.
K3S_AIRGAP=false
# K3S_ARCH is used by prepare-airgap-bundle.sh. Values: amd64, arm64, all.
AIRGAP_BUNDLE=
AIRGAP_BUNDLE_AMD64=
AIRGAP_BUNDLE_ARM64=
# Optional K3s binary and install script downloaded by download-k3s-assets.sh.
# Set K3S_ASSETS_PRELOADED=true when these paths already exist on every remote node.
K3S_ASSETS_PRELOADED=false
K3S_BINARY=
K3S_BINARY_AMD64=
K3S_BINARY_ARM64=
K3S_INSTALL_SCRIPT=
# Optional raw K3s airgap image tarball. When set, deploy script copies it to
# /var/lib/rancher/k3s/agent/images/ so K3s can auto import it.
K3S_IMAGE_TAR=
K3S_IMAGE_TAR_AMD64=
K3S_IMAGE_TAR_ARM64=
K3S_ARCH=amd64

# Local artifact output
ARTIFACT_DIR=./k3s/artifacts
