# SSH settings
SSH_USER=root
SSH_PORT=22
SSH_OPTS="-o StrictHostKeyChecking=accept-new"

# Nodes running HAProxy and Keepalived
LB1_NAME=k3s-master-1
LB1_HOST=192.168.1.11
LB2_NAME=k3s-master-2
LB2_HOST=192.168.1.12
LB3_NAME=k3s-master-3
LB3_HOST=192.168.1.13

# If LB*_HOST are not set, the script also accepts MASTER*_HOST from k3s/prod.env.

# VIP and frontend
VIP=192.168.1.10
VIP_CIDR=24
NODE_INTERFACE=eth0
API_LB_PORT=8443

# Backend service targets
BACKEND_PORT=6443
BACKEND1_NAME=k3s-master-1
BACKEND1_HOST=192.168.1.11
BACKEND2_NAME=k3s-master-2
BACKEND2_HOST=192.168.1.12
BACKEND3_NAME=k3s-master-3
BACKEND3_HOST=192.168.1.13

# If BACKEND*_HOST are not set, the script also accepts MASTER*_HOST from k3s/prod.env.

# Keepalived
VRRP_ROUTER_ID=51
VRRP_AUTH_PASS=k3s-ha
VRRP_PRIORITIES=120,110,100

# Offline mode assumes haproxy and keepalived are already installed from an OS repo or RPM/DEB bundle.
LB_AIRGAP=false

