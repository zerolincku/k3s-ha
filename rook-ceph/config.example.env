# Kubernetes config
KUBECONFIG=

# Namespace
ROOK_CEPH_NAMESPACE=rook-ceph

# Versions
# 当前默认值按 2026-06-05 Rook/Ceph 官方文档选择，生产应结合公司基线固定版本。
ROOK_CEPH_ROOK_VERSION=v1.19.6
ROOK_CEPH_IMAGE=quay.io/rook/ceph:v1.19.6
ROOK_CEPH_CEPH_IMAGE=quay.io/ceph/ceph:v19.2.3
ROOK_CEPH_IMAGE_PLATFORM=linux/arm64
# K8s 合法值: IfNotPresent / Never / Always；离线导入场景默认使用 IfNotPresent。
ROOK_CEPH_IMAGE_PULL_POLICY=IfNotPresent

# Rook manifest URLs
ROOK_CEPH_ARTIFACT_DIR=./rook-ceph/artifacts
ROOK_CEPH_CRDS_MANIFEST=
ROOK_CEPH_COMMON_MANIFEST=
ROOK_CEPH_CSI_OPERATOR_MANIFEST=
ROOK_CEPH_OPERATOR_MANIFEST=
ROOK_CEPH_CRDS_URL=https://raw.githubusercontent.com/rook/rook/v1.19.6/deploy/examples/crds.yaml
ROOK_CEPH_COMMON_URL=https://raw.githubusercontent.com/rook/rook/v1.19.6/deploy/examples/common.yaml
ROOK_CEPH_CSI_OPERATOR_URL=https://raw.githubusercontent.com/rook/rook/v1.19.6/deploy/examples/csi-operator.yaml
ROOK_CEPH_OPERATOR_URL=https://raw.githubusercontent.com/rook/rook/v1.19.6/deploy/examples/operator.yaml

# Image archives
ROOK_CEPH_IMAGE_TAR=
ROOK_CEPH_CEPH_IMAGE_TAR=
ROOK_CEPH_EXTRA_IMAGES=
ROOK_CEPH_EXTRA_IMAGE_TARS=
ROOK_CEPH_IMAGE_DOWNLOAD_TOOL=docker
CRANE_BIN=crane
ROOK_CEPH_DOCKER_PULL_RETRIES=5
ROOK_CEPH_DOCKER_PULL_RETRY_DELAY=10
ROOK_CEPH_CURL_INSECURE=false

# CephCluster
ROOK_CEPH_DATA_DIR_HOST_PATH=/var/lib/rook
ROOK_CEPH_USE_ALL_NODES=true
ROOK_CEPH_USE_ALL_DEVICES=false
# 生产建议显式指定裸数据盘；多个设备用英文逗号分隔，例如: /dev/vdb,/dev/vdc
ROOK_CEPH_DEVICES=/dev/vdb
ROOK_CEPH_REPLICATED_REQUIRE_SAFE_REPLICA_SIZE=true
ROOK_CEPH_MON_COUNT=3
ROOK_CEPH_ALLOW_MULTIPLE_PER_NODE=false
ROOK_CEPH_MGR_COUNT=2
ROOK_CEPH_DASHBOARD_ENABLED=true
ROOK_CEPH_DASHBOARD_SSL=false
ROOK_CEPH_WAIT_TIMEOUT=1200s

# CephFS
ROOK_CEPH_FS_NAME=cephfs
ROOK_CEPH_FS_MDS_ACTIVE_COUNT=1
ROOK_CEPH_FS_MDS_ACTIVE_STANDBY=true
ROOK_CEPH_FS_METADATA_POOL_SIZE=3
ROOK_CEPH_FS_DATA_POOL_SIZE=3
ROOK_CEPH_FS_STORAGE_CLASS=rook-cephfs
ROOK_CEPH_FS_RECLAIM_POLICY=Retain
ROOK_CEPH_FS_ALLOW_VOLUME_EXPANSION=true

# RGW / S3
ROOK_CEPH_OBJECT_STORE_NAME=objectstore
ROOK_CEPH_OBJECT_STORE_METADATA_POOL_SIZE=3
ROOK_CEPH_OBJECT_STORE_DATA_POOL_SIZE=3
ROOK_CEPH_OBJECT_STORE_GATEWAY_INSTANCES=2
ROOK_CEPH_OBJECT_STORE_GATEWAY_PORT=80
ROOK_CEPH_OBJECT_STORE_PRESERVE_POOLS_ON_DELETE=true
ROOK_CEPH_BUCKET_STORAGE_CLASS=rook-ceph-bucket
ROOK_CEPH_BUCKET_RECLAIM_POLICY=Retain
ROOK_CEPH_OBJECT_USER_NAME=admin
ROOK_CEPH_OBJECT_USER_DISPLAY_NAME="Rook Ceph RGW Admin"

# Operator deployment
ROOK_CEPH_INSTALL_OPERATOR=true
ROOK_CEPH_INSTALL_CLUSTER=true
ROOK_CEPH_INSTALL_FILESYSTEM=true
ROOK_CEPH_INSTALL_OBJECT_STORE=true

# Image upload to K3s nodes
# 多个节点用英文逗号分隔，例如: k3s-master-1,k3s-master-2,k3s-master-3
ROOK_CEPH_NODE_SSH_HOSTS=
ROOK_CEPH_NODE_NAMES=
SSH_USER=root
SSH_PORT=22
SSH_OPTS="-o StrictHostKeyChecking=accept-new"
ROOK_CEPH_K3S_IMAGES_DIR=/var/lib/rancher/k3s/agent/images
ROOK_CEPH_RESTART_K3S_AFTER_IMAGE_UPLOAD=false
ROOK_CEPH_RESET_K3S_IMAGE_CACHE=false
